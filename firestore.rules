rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Catch-all Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // --- Entity Validations ---

    function isValidUser(data) {
      return data.uid is string && data.uid == request.auth.uid &&
             data.email is string && data.email.size() <= 256 &&
             (data.displayName == null || (data.displayName is string && data.displayName.size() <= 100)) &&
             (data.photoURL == null || (data.photoURL is string && data.photoURL.size() <= 512)) &&
             (data.avatarId == null || (data.avatarId is string && data.avatarId.size() <= 50)) &&
             (data.isArtistActive == null || data.isArtistActive is bool) &&
             data.createdAt == request.time;
    }

    function isValidArtworkReg(data) {
      return data.userId == request.auth.uid &&
             data.artworkId is string && data.artworkId.size() <= 128 &&
             data.certificateNumber is string && data.certificateNumber.size() <= 64 &&
             data.registeredAt == request.time;
    }

    function isValidArtistProfile(data) {
      return data.userId == request.auth.uid &&
             (data.bio == null || (data.bio is string && data.bio.size() <= 2000)) &&
             (data.style == null || (data.style is string && data.style.size() <= 500)) &&
             (data.website == null || (data.website is string && data.website.size() <= 512)) &&
             (data.socialLinks == null || data.socialLinks is map) &&
             data.isActive is bool &&
             data.updatedAt == request.time;
    }

    function isValidSubmission(data) {
      return data.userId == request.auth.uid &&
             data.title is string && data.title.size() <= 200 &&
             data.imageUrl is string && data.imageUrl.size() <= 1000 &&
             data.status == "pending" &&
             data.submittedAt == request.time;
    }

    function isValidInteraction(data) {
      return data.userId == request.auth.uid &&
             data.targetId is string && data.targetId.size() <= 128 &&
             data.type in ["like", "follow"] &&
             data.createdAt == request.time;
    }

    // --- Matches ---

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming()) && incoming().keys().size() >= 3;
      allow update: if isOwner(userId) && 
        incoming().uid == existing().uid &&
        incoming().createdAt == existing().createdAt &&
        incoming().updatedAt == request.time &&
        incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'avatarId', 'isArtistActive', 'updatedAt']);
    }

    match /registeredArtworks/{artworkRegId} {
      allow get: if isSignedIn() && isOwner(existing().userId);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isVerified() && isValidArtworkReg(incoming()) && isValidId(artworkRegId);
      allow delete: if isOwner(existing().userId);
    }

    match /artistProfiles/{userId} {
      allow read: if true; // Public profiles
      allow create: if isOwner(userId) && isValidArtistProfile(incoming());
      allow update: if isOwner(userId) && 
        incoming().userId == existing().userId &&
        isValidArtistProfile(incoming()) &&
        incoming().diff(existing()).affectedKeys().hasOnly(['bio', 'style', 'socialLinks', 'website', 'isActive', 'updatedAt']);
    }

    match /submissions/{submissionId} {
      allow get: if isSignedIn() && (isOwner(existing().userId) || isOwner(resource.data.userId));
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isVerified() && isValidSubmission(incoming()) && isValidId(submissionId);
      allow delete: if isOwner(existing().userId) && existing().status == "pending";
    }

    match /interactions/{interactionId} {
      allow read: if true; // Public counts or lists
      allow create: if isVerified() && isValidInteraction(incoming()) && isValidId(interactionId);
      allow delete: if isOwner(existing().userId);
    }
  }
}
